{
  "name": "arte-odyssey",
  "private": true,
  "description": "k8o's react ui library",
  "license": "MIT",
  "author": "k8o",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k35o/ArteOdyssey.git"
  },
  "type": "module",
  "scripts": {
    "build": "vp run build --filter './packages/*' --filter './apps/*'",
    "test": "vp run test -r",
    "test:ui": "vp run test:ui -r",
    "test:coverage": "vp run test:coverage -r",
    "typecheck": "vp run typecheck -r",
    "check": "vp run check -r",
    "check:write": "vp run check:write -r",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@types/node": "24.12.0",
    "agent-browser": "0.23.4",
    "cosmiconfig": "latest",
    "playwright": "1.59.1",
    "typescript": "6.0.2",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "packageManager": "pnpm@10.33.0"
}
